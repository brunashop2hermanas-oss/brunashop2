generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  nombres   String
  apellidos String
  ci        String   @unique
  telefono  String
  username  String   @unique
  pin       String
  role      String   @default("EMPLEADO") // "ADMINISTRADOR", "EMPLEADO"
  permisos  String[] @default([]) // Array de permisos asignados
  ventas    Venta[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Clienta {
  id        String   @id @default(cuid())
  nombres   String
  apellidos String
  ci        String   @unique
  celular   String
  puntos    Int      @default(0)
  nivel     String   @default("Bronce")
  ventas    Venta[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Prenda {
  id              String   @id @default(cuid())
  nombre          String
  costoProveedor  Float
  precioVenta     Float
  precioOriginal  Float?   // Para gestionar descuentos y promociones
  categoria       String
  coleccion       String?
  descripcionLarga String? // Descripción detallada de la prenda
  marca           String?  // Opcional: marca de la prenda
  tallas          String[] // Arreglo de strings nativo de PostgreSQL
  stockPorTalla   Json?    // Objeto JSON para guardar el stock específico (ej: {"S": 5, "M": 2})
  colores         String[]
  material        String?
  imagenes        String[] // URLs de las fotos subidas
  imagenesPorColor Json?    // Objeto JSON para mapear color a URL de imagen
  stockCount      Int      @default(0)
  enLive          Boolean  @default(false)
  enPreventa      Boolean  @default(false)
  visiblePublico  Boolean  @default(true) // Controla si la prenda es visible en la tienda pública
  
  isConjunto      Boolean  @default(false)
  piezasId        String[] // Array de IDs de prendas que lo componen
  piezasDetalle   Json?    // Objeto JSON para guardar el detalle de las prendas asignadas al combo (talla, color, cantidad)
  
  estado          String   @default("DISPONIBLE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  
  ventaItems      VentaItem[]

  @@index([estado, createdAt])
  @@index([categoria])
  @@index([enLive, enPreventa])
}

model Venta {
  id            String      @id @default(cuid())
  fecha         DateTime    @default(now())
  total         Float
  metodoPago    String      // "QR", "EFECTIVO", "TRANSFERENCIA"
  comprobante   String?     // URL de la imagen del pago
  guiaEnvioUrl  String?     // URL de la imagen de la guía de envío a terminal
  estado        String      @default("PENDIENTE_VERIFICACION") // ESPERANDO_PAGO, PENDIENTE_VERIFICACION, PREPARANDO, ENVIADO, ENTREGADO, CANCELADO, CANCELADO_POR_TIEMPO
  expiresAt     DateTime?   // Para reservas de stock temporales
  
  origen        String      @default("WEB") // "WEB", "POS", "TIKTOK"
  tipoEntrega   String      @default("RECOJO_TIENDA") // "RECOJO_TIENDA", "ENVIO"
  destino       String?     // Dirección de envío (Departamento)
  provinciaDestino String?  // Provincia específica
  municipioDestino String?  // Municipio específico
  
  depositanteNombres   String?
  depositanteApPaterno String?
  depositanteApMaterno String?
  depositanteCuenta    String?
  
  receptorDiferente Boolean @default(false)
  receptorNombres String?
  receptorApPaterno String?
  receptorApMaterno String?
  receptorCi String?
  receptorCelular String?
  
  empresaBusesPreferida String?
  
  terminosAceptados Boolean @default(false)
  fechaAceptacion   DateTime?
  ipAceptacion      String?
  puntosOtorgados   Boolean @default(false)
  
  vendedorId    String?
  vendedor      User?       @relation(fields: [vendedorId], references: [id])
  
  clientaId     String?
  clienta       Clienta?    @relation(fields: [clientaId], references: [id])
  
  items         VentaItem[]
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([fecha, estado])
  @@index([clientaId])
}

model VentaItem {
  id        String  @id @default(cuid())
  ventaId   String
  venta     Venta   @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  prendaId  String
  prenda    Prenda  @relation(fields: [prendaId], references: [id])
  precio    Float
  cantidad  Int     @default(1)
  talla     String?
  color     String?
  empaquetado Boolean @default(false)

  @@index([ventaId])
  @@index([prendaId])
}

model Configuracion {
  id                    Int      @id @default(1)
  bancoNombre           String   @default("Banco Unión")
  bancoCuenta           String   @default("10000012345678")
  bancoTitular          String   @default("BrunaShop2")
  qrImagen              String?
  instagramUrl          String?
  tiktokUrl             String?
  whatsappUrl           String?
  facebookUrl           String?
  footerDescripcion     String?  // Texto de la marca en el footer
  terminosCondiciones   String?  @db.Text
  politicasEnvio        String?  @db.Text
  politicaPrivacidad    String?  @db.Text
  politicaDevoluciones  String?  @db.Text
  identidadTienda       String?  @db.Text
  jurisdiccion          String?  @db.Text
  usarControlFinanciero Boolean  @default(true)
  liveActivo            Boolean  @default(false)
  tiempoReservaMinutos  Int      @default(4)
  tiempoLlenadoDatosMinutos Int  @default(10)
  destinosHabilitados   Json?    // Array de { departamento: "...", provincias: ["..."] }
  categoriasPrendas     String[] @default(["Vestidos", "Conjuntos", "Blusas y Tops", "Pantalones y Jeans", "Chaquetas y Abrigos", "Enterizos", "Ofertas / Sale"])
  liveHorariosRecurrentes Json? // Array de { diaSemana: number, hora: string } donde 0=Dom, 1=Lun, etc.
  planSupabase          String   @default("Gratuito") // "Gratuito" o "Pro"
  msgAprobadoLocal      String?  @db.Text
  msgAprobadoNacional   String?  @db.Text
  msgRechazadoLocal     String?  @db.Text
  msgRechazadoNacional  String?  @db.Text
  msgGuiaLocal          String?  @db.Text
  msgGuiaNacional       String?  @db.Text
  updatedAt             DateTime @updatedAt
}
